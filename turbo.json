{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "mobile#build": {
      "dependsOn":["^build"],
      "outputs": ["build/**"],
      "cache": true
    },
    "mobile#test": {
      "cache": true
    }
  }
} 